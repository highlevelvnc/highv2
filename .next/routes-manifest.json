      "page": "/insights/[slug]",
      "regex": "^/insights/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/insights/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/work/[slug]",
      "regex": "^/work/([^/]+?)(?:/)?$",
